      "boundElements": [],
      "updated": 1778033539349,
      "link": null,
      "locked": false,
      "text": "which user can do what\nthis is called authorization.\nrbac system -> role based\naccess control system.\nexample -> spotify\nnormal user can only listen\nto songs, but an artist\nlisten and also create\nsongs.\nthe artist have authorization\nto create songs along with\nlistening.",
      "fontSize": 13.191722602242512,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "which user can do what\nthis is called authorization.\nrbac system -> role based\naccess control system.\nexample -> spotify\nnormal user can only listen\nto songs, but an artist\nlisten and also create\nsongs.\nthe artist have authorization\nto create songs along with\nlistening.",
      "autoResize": true,
      "lineHeight": 1.25
